# Generated by moirai/bin/install — do not edit by hand.
# To re-generate: bin/install {{AGENT_NAME}}
# To tune behaviour: edit .github/agents/{{AGENT_NAME}}/config.yml

name: {{AGENT_NAME_TITLE}}
on:
{{TRIGGER_BLOCK}}

jobs:
  run:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    permissions:
{{PERMISSIONS}}
    steps:
{{IF_PR}}
      - name: Resolve PR context
        id: ctx
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          if [ "${{ github.event_name }}" = "pull_request" ]; then
            echo "pr_number=${{ github.event.pull_request.number }}" >> "$GITHUB_OUTPUT"
            echo "base_sha=${{ github.event.pull_request.base.sha }}" >> "$GITHUB_OUTPUT"
            echo "head_sha=${{ github.event.pull_request.head.sha }}" >> "$GITHUB_OUTPUT"
            echo "head_ref=${{ github.event.pull_request.head.ref }}" >> "$GITHUB_OUTPUT"
            echo "head_repo=${{ github.event.pull_request.head.repo.full_name }}" >> "$GITHUB_OUTPUT"
          else
            PR_JSON=$(gh pr view "${{ github.event.inputs.pr_number }}" --repo "${{ github.repository }}" --json number,baseRefOid,headRefOid,headRefName,headRepository,headRepositoryOwner)
            echo "pr_number=${{ github.event.inputs.pr_number }}" >> "$GITHUB_OUTPUT"
            echo "base_sha=$(echo "$PR_JSON" | jq -r .baseRefOid)" >> "$GITHUB_OUTPUT"
            echo "head_sha=$(echo "$PR_JSON" | jq -r .headRefOid)" >> "$GITHUB_OUTPUT"
            echo "head_ref=$(echo "$PR_JSON" | jq -r .headRefName)" >> "$GITHUB_OUTPUT"
            echo "head_repo=$(echo "$PR_JSON" | jq -r '.headRepositoryOwner.login + "/" + .headRepository.name')" >> "$GITHUB_OUTPUT"
          fi

      - name: Skip if PR is from a fork
        if: steps.ctx.outputs.head_repo != github.repository
        run: |
          echo "::notice::PR is from a fork (${{ steps.ctx.outputs.head_repo }}). Skipping — cannot push commits back to fork branches."
          exit 0
{{ENDIF_PR}}
      - name: Check kill switch
        run: |
          if [ -f ".{{AGENT_NAME}}-pause" ]; then
            echo "::notice::{{AGENT_NAME_TITLE}} is paused (.{{AGENT_NAME}}-pause exists). Remove the file to resume."
            exit 0
          fi

      - uses: actions/checkout@v6
        with:
{{CHECKOUT_REF_LINE}}
          fetch-depth: 0
          submodules: recursive

      - name: Compute runtime envelope
        id: env
        run: |
          echo "today=$(date -u +%Y-%m-%d)" >> "$GITHUB_OUTPUT"
          echo "agent_repo_dir=$(pwd)/{{AGENT_REPO_DIR}}" >> "$GITHUB_OUTPUT"
          echo "agent_config_path=$(pwd)/.github/agents/{{AGENT_NAME}}/config.yml" >> "$GITHUB_OUTPUT"

      - name: Build prompt
        id: prompt
        run: |
          {
            echo 'content<<PROMPT_EOF'
            cat "{{AGENT_REPO_DIR}}/PROMPT.md"
            echo ''
            echo '---'
            echo ''
            echo '## Runtime context'
            echo "- AGENT_NAME: {{AGENT_NAME}}"
            echo "- AGENT_CONFIG_PATH: ${{ steps.env.outputs.agent_config_path }}"
            echo "- AGENT_REPO_DIR: ${{ steps.env.outputs.agent_repo_dir }}"
            echo "- TODAY: ${{ steps.env.outputs.today }}"
{{IF_PR}}
            echo "- PR_NUMBER: ${{ steps.ctx.outputs.pr_number }}"
            echo "- PR_BASE_SHA: ${{ steps.ctx.outputs.base_sha }}"
            echo "- PR_HEAD_SHA: ${{ steps.ctx.outputs.head_sha }}"
{{ENDIF_PR}}
            echo ''
            echo 'Execute the workflow defined above.'
            echo 'PROMPT_EOF'
          } >> "$GITHUB_OUTPUT"

      - name: Run {{AGENT_NAME}}
        uses: anthropics/claude-code-action@v1
        with:
          prompt: ${{ steps.prompt.outputs.content }}
          claude_args: "--allowedTools '{{ALLOWED_TOOLS}}'"
          anthropic_api_key: ${{ secrets.ANTHROPIC_API_KEY }}
          github_token: ${{ secrets.GITHUB_TOKEN }}
        env:
          AGENT_NAME: {{AGENT_NAME}}
          AGENT_CONFIG_PATH: ${{ steps.env.outputs.agent_config_path }}
          AGENT_REPO_DIR: ${{ steps.env.outputs.agent_repo_dir }}
          TODAY: ${{ steps.env.outputs.today }}
          # GH_TOKEN/GITHUB_TOKEN are surfaced so agents can call `gh` via Bash
          # (e.g. `gh issue create`, `gh issue list`). The claude-code-action's
          # MCP github tools require a separate mcp_config; we default to gh CLI
          # because it works without extra wiring.
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
{{IF_PR}}
          PR_NUMBER: ${{ steps.ctx.outputs.pr_number }}
          PR_BASE_SHA: ${{ steps.ctx.outputs.base_sha }}
          PR_HEAD_SHA: ${{ steps.ctx.outputs.head_sha }}
{{ENDIF_PR}}
{{IF_INBOX}}

      - name: Commit inbox changes back
        env:
          HEAD_REF: ${{ steps.ctx.outputs.head_ref }}
        run: |
          if git diff --quiet -- {{INBOX_PATH}}; then
            echo "::notice::No changes to {{INBOX_PATH}} — agent produced no diff."
            exit 0
          fi

          git config user.name  "{{AGENT_NAME}}-bot"
          git config user.email "{{AGENT_NAME}}-bot@users.noreply.github.com"

          git add {{INBOX_PATH}}
          git commit \
            -m "chore({{AGENT_NAME}}): refresh PR #${{ steps.ctx.outputs.pr_number }} findings" \
            -m "Auto-generated by .github/workflows/{{AGENT_NAME}}.yml via .moirai/adapters/claude-code-action."
          git push origin "HEAD:${HEAD_REF}"
{{ENDIF_INBOX}}
