#!/usr/bin/env bash
# moirai/bin/install — install an agent into the current repo.
#
# Usage:
#   .moirai/bin/install <agent-name> [--trigger <trigger>] [--sink <sink>] [--adapter <adapter>] [--force]
#
# Reads ../registry.yml relative to this script to find the agent.
# Submodules the agent at its pinned tag, scaffolds .github/agents/<name>/config.yml
# from the agent's defaults.yml, and drops a workflow from the chosen adapter template.
#
# Requires: bash 4+, git, python3 (for YAML reading and template substitution).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MOIRAI_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
REGISTRY="${MOIRAI_DIR}/registry.yml"

# --- Arg parsing -------------------------------------------------------------

AGENT_NAME=""
TRIGGER_OVERRIDE=""
SINK_OVERRIDE=""
ADAPTER_OVERRIDE=""
FORCE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --trigger) TRIGGER_OVERRIDE="$2"; shift 2 ;;
    --sink)    SINK_OVERRIDE="$2"; shift 2 ;;
    --adapter) ADAPTER_OVERRIDE="$2"; shift 2 ;;
    --force)   FORCE=1; shift ;;
    --help|-h)
      sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    -*)
      echo "error: unknown flag $1" >&2
      exit 2
      ;;
    *)
      if [[ -z "$AGENT_NAME" ]]; then
        AGENT_NAME="$1"
      else
        echo "error: unexpected positional arg $1" >&2
        exit 2
      fi
      shift
      ;;
  esac
done

if [[ -z "$AGENT_NAME" ]]; then
  echo "usage: install <agent-name> [--trigger <t>] [--sink <s>] [--adapter <a>] [--force]" >&2
  exit 2
fi

# --- Read a value from a YAML file -------------------------------------------
yaml_get() {
  python3 - "$1" "$2" <<'PY'
import sys, re

path = sys.argv[2].split(".")
target = ".".join(path)
stack = []

with open(sys.argv[1]) as f:
    for raw in f:
        line = raw.rstrip("\n")
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        indent = (len(line) - len(line.lstrip(" "))) // 2
        m = re.match(r"^\s*([A-Za-z0-9_-]+):\s*(.*?)\s*$", line)
        if not m:
            continue
        key, val = m.group(1), m.group(2)
        stack = stack[:indent] + [key]
        if ".".join(stack) == target and val != "":
            print(val)
            sys.exit(0)
sys.exit(1)
PY
}

# --- Resolve agent from registry --------------------------------------------

AGENT_REPO=$(yaml_get "$REGISTRY" "agents.${AGENT_NAME}.repo") || {
  echo "error: agent '${AGENT_NAME}' not found in registry.yml" >&2; exit 1; }
AGENT_VERSION=$(yaml_get "$REGISTRY" "agents.${AGENT_NAME}.version") || {
  echo "error: no version pinned for '${AGENT_NAME}' in registry.yml" >&2; exit 1; }
AGENT_DEFAULT_ADAPTER=$(yaml_get "$REGISTRY" "agents.${AGENT_NAME}.default_adapter" || echo "claude-code-action")
AGENT_DEFAULT_TRIGGER=$(yaml_get "$REGISTRY" "agents.${AGENT_NAME}.default_trigger" || echo "schedule")
AGENT_DEFAULT_SINK=$(yaml_get "$REGISTRY" "agents.${AGENT_NAME}.default_sink" || echo "issues")

ADAPTER="${ADAPTER_OVERRIDE:-$AGENT_DEFAULT_ADAPTER}"
TRIGGER="${TRIGGER_OVERRIDE:-$AGENT_DEFAULT_TRIGGER}"
SINK="${SINK_OVERRIDE:-$AGENT_DEFAULT_SINK}"

TEMPLATE="${MOIRAI_DIR}/adapters/${ADAPTER}/workflow.yml.template"
if [[ ! -f "$TEMPLATE" ]]; then
  echo "error: adapter '${ADAPTER}' has no workflow.yml.template at ${TEMPLATE}" >&2
  exit 1
fi

# --- Add agent as submodule -------------------------------------------------

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

AGENT_SUBMODULE_PATH=".agents/${AGENT_NAME}"
if [[ ! -d "$AGENT_SUBMODULE_PATH" ]]; then
  git submodule add -b main "$AGENT_REPO" "$AGENT_SUBMODULE_PATH"
  ( cd "$AGENT_SUBMODULE_PATH" && git fetch --tags origin && git checkout "$AGENT_VERSION" )
  echo "+ added submodule ${AGENT_SUBMODULE_PATH} @ ${AGENT_VERSION}"
else
  echo "= submodule ${AGENT_SUBMODULE_PATH} already exists, skipping submodule add"
fi

# --- Scaffold config.yml from the agent's defaults.yml ----------------------

CONFIG_DIR=".github/agents/${AGENT_NAME}"
CONFIG_FILE="${CONFIG_DIR}/config.yml"
mkdir -p "$CONFIG_DIR"

if [[ -f "$CONFIG_FILE" && "$FORCE" -ne 1 ]]; then
  echo "= ${CONFIG_FILE} already exists, leaving in place (use --force to regenerate)"
else
  # Strip the defaults.yml leading comment block (avoid double headers) and prepend our own.
  python3 - "${AGENT_SUBMODULE_PATH}/defaults.yml" "$CONFIG_FILE" \
    "$AGENT_NAME" "$AGENT_VERSION" "$AGENT_SUBMODULE_PATH" <<'PY'
import sys
lines = open(sys.argv[1]).read().splitlines()
# Drop leading comment-or-blank lines so we can prepend our own header.
i = 0
while i < len(lines) and (lines[i].strip() == "" or lines[i].lstrip().startswith("#")):
    i += 1
body = "\n".join(lines[i:]).rstrip() + "\n"
header = (
    f"# {sys.argv[3]} agent — repo-specific configuration\n"
    f"# Scaffolded from {sys.argv[3]}@{sys.argv[4]} defaults.yml via .moirai/bin/install.\n"
    f"# Validated against {sys.argv[5]}/schema.json.\n"
    f"# Any field omitted here falls back to {sys.argv[5]}/defaults.yml.\n"
    f"\n"
)
open(sys.argv[2], "w").write(header + body)
PY
  echo "+ scaffolded ${CONFIG_FILE}"
fi

# --- Resolve inbox path (for inbox sink) -------------------------------------

INBOX_PATH="notes/inbox.md"
if [[ "$SINK" == "inbox" ]]; then
  # Allow the agent's defaults.yml to override (e.g. inbox_path: docs/inbox.md)
  RESOLVED=$(yaml_get "${AGENT_SUBMODULE_PATH}/defaults.yml" "inbox_path" 2>/dev/null || true)
  if [[ -n "$RESOLVED" ]]; then
    INBOX_PATH="$RESOLVED"
  fi
fi

# --- Render the workflow from the adapter template --------------------------

WORKFLOW_FILE=".github/workflows/${AGENT_NAME}.yml"
mkdir -p .github/workflows

AGENT_NAME_TITLE="$(echo "$AGENT_NAME" | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) substr($i,2)} 1')"

# Trigger block (workflow_dispatch always included; pr also gets the pr_number input)
case "$TRIGGER" in
  schedule)
    TRIGGER_BLOCK=$'  schedule:\n    - cron: "0 3 * * *"\n  workflow_dispatch:'
    IS_PR=0
    ;;
  pull_request)
    TRIGGER_BLOCK=$'  pull_request:\n    types: [opened, synchronize, reopened]\n  workflow_dispatch:\n    inputs:\n      pr_number:\n        description: "PR number to run against (manual run)"\n        required: true'
    IS_PR=1
    ;;
  workflow_dispatch)
    TRIGGER_BLOCK=$'  workflow_dispatch:'
    IS_PR=0
    ;;
  *) echo "error: unknown trigger '${TRIGGER}' (supported: schedule, pull_request, workflow_dispatch)" >&2; exit 1 ;;
esac

# Permissions, derived from sink
case "$SINK" in
  issues)     PERMISSIONS_BLOCK=$'      contents: read\n      id-token: write\n      issues: write'; IS_INBOX=0 ;;
  inbox)      PERMISSIONS_BLOCK=$'      contents: write\n      id-token: write\n      pull-requests: read'; IS_INBOX=1 ;;
  summary)    PERMISSIONS_BLOCK=$'      contents: read\n      id-token: write'; IS_INBOX=0 ;;
  pr-comment) PERMISSIONS_BLOCK=$'      contents: read\n      id-token: write\n      pull-requests: write'; IS_INBOX=0 ;;
  *) echo "error: unknown sink '${SINK}' (supported: issues, inbox, summary, pr-comment)" >&2; exit 1 ;;
esac

# Checkout ref line — only set for pull_request (uses head_ref from ctx step)
if [[ "$IS_PR" -eq 1 ]]; then
  CHECKOUT_REF_LINE="          ref: \${{ steps.ctx.outputs.head_ref }}"
else
  CHECKOUT_REF_LINE=""
fi

# Allowed tools — read from the agent's AGENT.md frontmatter if it declares them
ALLOWED_TOOLS="Bash,Read,Grep,Glob"
if grep -q "^allowed_tools:" "${AGENT_SUBMODULE_PATH}/AGENT.md" 2>/dev/null; then
  ALLOWED_TOOLS="$(grep "^allowed_tools:" "${AGENT_SUBMODULE_PATH}/AGENT.md" | sed 's/^allowed_tools:[ ]*//')"
fi

if [[ -f "$WORKFLOW_FILE" && "$FORCE" -ne 1 ]]; then
  echo "= ${WORKFLOW_FILE} already exists, leaving in place (use --force to regenerate)"
else
  python3 - "$TEMPLATE" "$WORKFLOW_FILE" \
    "$AGENT_NAME" "$AGENT_NAME_TITLE" "$AGENT_SUBMODULE_PATH" \
    "$ALLOWED_TOOLS" "$TRIGGER_BLOCK" "$PERMISSIONS_BLOCK" \
    "$CHECKOUT_REF_LINE" "$INBOX_PATH" "$IS_PR" "$IS_INBOX" <<'PY'
import sys, re

(_, src_path, dst_path, agent, title, repo_dir, tools,
 trigger_block, permissions, checkout_ref, inbox_path, is_pr, is_inbox) = sys.argv
is_pr = bool(int(is_pr))
is_inbox = bool(int(is_inbox))

src = open(src_path).read()

# Conditional blocks: lines bounded by `{{IF_X}}` and `{{ENDIF_X}}`.
# If flag is true: strip the marker lines, keep the inner block.
# If flag is false: strip the marker lines AND the inner block.
def conditional(text, name, keep):
    # The markers appear on lines by themselves (after stripping leading whitespace).
    pattern = re.compile(
        r"^[ \t]*\{\{IF_" + name + r"\}\}[ \t]*\n(.*?)^[ \t]*\{\{ENDIF_" + name + r"\}\}[ \t]*\n",
        re.MULTILINE | re.DOTALL,
    )
    return pattern.sub(lambda m: m.group(1) if keep else "", text)

# Order matters: process the outer INBOX block first, then the inner PR / NOT_PR
# markers (which may live inside an INBOX block as well as at the top level).
src = conditional(src, "INBOX", is_inbox)
src = conditional(src, "PR", is_pr)
src = conditional(src, "NOT_PR", not is_pr)

# Then substitute scalar placeholders.
replacements = {
    "{{AGENT_NAME}}":       agent,
    "{{AGENT_NAME_TITLE}}": title,
    "{{AGENT_REPO_DIR}}":   repo_dir,
    "{{ALLOWED_TOOLS}}":    tools,
    "{{TRIGGER_BLOCK}}":    trigger_block,
    "{{PERMISSIONS}}":      permissions,
    "{{CHECKOUT_REF_LINE}}": checkout_ref,
    "{{INBOX_PATH}}":       inbox_path,
}
for k, v in replacements.items():
    src = src.replace(k, v)

# Tidy: drop blank-line runs created by removing optional blocks.
src = re.sub(r"\n{3,}", "\n\n", src)

# Drop the empty CHECKOUT_REF_LINE line that becomes a blank line after substitution
src = re.sub(r"\n[ ]*\n([ ]+fetch-depth)", r"\n\1", src)

open(dst_path, "w").write(src)
PY
  echo "+ rendered ${WORKFLOW_FILE} (adapter: ${ADAPTER}, trigger: ${TRIGGER}, sink: ${SINK})"
fi

# --- Done -------------------------------------------------------------------

cat <<EOF

Done. To finish:

  1. Edit ${CONFIG_FILE} to tune the agent for this repo
  2. Make sure these repo secrets are set:
       - ANTHROPIC_API_KEY  (gh secret set ANTHROPIC_API_KEY)
  3. Commit the changes:
       git add ${CONFIG_FILE} ${WORKFLOW_FILE} .gitmodules ${AGENT_SUBMODULE_PATH}
       git commit -m "chore: install ${AGENT_NAME}@${AGENT_VERSION} via moirai"
  4. Push and watch the first run.

EOF
